new file mode 100644
index 00000000000..becacaed77e
--- /dev/null
+++ b/source4/torture/smb2/ea.c
@@ -0,0 +1,152 @@
+/*
+   Unix SMB/CIFS implementation.
+   SMB2 EA tests
+
+   Copyright (C) Ralph Boehme 2022
+
